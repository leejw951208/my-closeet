# 모노레포 루트 환경 변수 예시 파일. 실제 값은 .env에 정의한다.

# PostgreSQL (docker-compose가 읽음)
POSTGRES_USER=mycloset
POSTGRES_PASSWORD=mycloset_dev
POSTGRES_DB=mycloset
POSTGRES_PORT=5432

# Flutter dart-define (Makefile이 자동 주입)
# iOS 시뮬레이터: http://localhost:3000
# Android 에뮬레이터: http://10.0.2.2:3000
API_BASE_URL=http://localhost:3000
APP_ENV=dev
# SENTRY_DSN=  # 운영용. 비워두면 dart-define에 포함되지 않는다.

# API (NestJS)
# SMS_DEV_MODE=true 이면 솔라피로 실제 SMS를 보내지 않고 콘솔에 OTP 코드를 출력한다.
SMS_DEV_MODE=true
# 실발송용 솔라피 자격(SMS_DEV_MODE=false일 때만 필요)
# SOLAPI_API_KEY=
# SOLAPI_API_SECRET=
# SOLAPI_SENDER=+8210xxxxxxxx
# JWT_SECRET=dev-only-change-me
