# NestJS API 환경 변수 예시.

NODE_ENV=development
PORT=3000

# packages/database의 DATABASE_URL과 동일한 값을 사용한다.
DATABASE_URL="postgresql://mycloset:mycloset_dev@localhost:5432/mycloset?schema=public"

# Solapi SMS (OTP 발송)
# true이면 실제 SMS 발송 없이 콘솔에 코드를 출력하고 /auth/otp/send 응답에 devCode를 동봉한다.
# 운영(NODE_ENV=production)에서는 반드시 false.
SMS_DEV_MODE=true
SOLAPI_API_KEY="your-solapi-api-key"
SOLAPI_API_SECRET="your-solapi-api-secret"
SOLAPI_SENDER="01000000000"

# JWT 서명 (32바이트 이상 무작위 문자열)
JWT_SECRET="change-me-to-a-long-random-string-of-at-least-32-bytes"
JWT_ACCESS_TTL_MIN=30
JWT_REFRESH_TTL_DAYS=30
OTP_SESSION_TTL_MIN=5
