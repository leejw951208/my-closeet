// кҙҖл Ё PRD. docs/plan/pm/prd-mvp.md US-02В·US-03В·US-04В·US-06В·US-07.

model Closet {
  id        String   @id @default(uuid(7)) @db.Uuid
  userId    String   @unique @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  items Item[]
}

model Item {
  id           String       @id @default(uuid(7)) @db.Uuid
  closetId     String       @db.Uuid
  closet       Closet       @relation(fields: [closetId], references: [id], onDelete: Cascade)
  photoUrl     String
  category     ItemCategory
  emoji        String?
  colorHex     String?
  brand        String?
  season       Season?
  aiConfidence Float?
  registeredAt DateTime     @default(now())
  deletedAt    DateTime?

  outfitItems OutfitItem[]

  @@index([closetId, category])
}

enum ItemCategory {
  TOP
  BOTTOM
  DRESS
  OUTER
  SHOES
  HAT
  BAG
  ACCESSORY
}

enum Season {
  SPRING
  SUMMER
  FALL
  WINTER
  ALL
}
